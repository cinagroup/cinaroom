# 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# Cloudflare Tunnel 配置
CLOUDFLARE_TUNNEL_ID=your-tunnel-id-here
CLOUDFLARE_HOSTNAME=example.com
CLOUDFLARE_SECRET=your-secret-here
CLOUDFLARE_SERVICE_TOKEN=your-service-token-here

# WebSocket 终端配置
TOKEN_EXPIRY_HOURS=24
SESSION_TIMEOUT_MINUTES=30
MAX_CONNECTIONS=100
HEARTBEAT_INTERVAL_SECONDS=60

# 云端中转配置
RELAY_MAX_CONNECTIONS=1000
RELAY_BUFFER_SIZE=100
FORWARD_TIMEOUT_SECONDS=30

# Redis 配置（可选，用于集群部署）
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# 日志配置
LOG_LEVEL=info
LOG_FORMAT=json

# 安全配置
ALLOWED_ORIGINS=https://example.com,wss://example.com
RATE_LIMIT_REQUESTS_PER_MINUTE=60
