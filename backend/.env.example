# CinaRoom 后端环境变量配置

# ===========================================
# 服务器配置
# ===========================================
SERVER_PORT=8080
SERVER_MODE=release  # debug | release

# ===========================================
# 数据库配置（PostgreSQL）
# ===========================================
DB_HOST=postgresql-master.cinatoken.svc.cluster.local
DB_PORT=5432
DB_USER=multipass
DB_PASSWORD=CHANGE_ME
DB_NAME=cinatoken
DB_SCHEMA=multipass
DB_SSLMODE=require

# ===========================================
# Redis 配置（会话存储）
# ===========================================
REDIS_HOST=redis.cinatoken.svc.cluster.local
REDIS_PORT=6379
REDIS_PASSWORD=

# ===========================================
# JWT 配置
# ===========================================
JWT_SECRET=CHANGE_ME_GENERATE_A_SECURE_KEY_HERE
JWT_EXPIRE_HOURS=24

# ===========================================
# CinaToken OAuth 配置（重要！）
# ===========================================
# 在 CinaToken 管理后台申请 OAuth 客户端凭证
CINATOKEN_BASE_URL=https://cinatoken.com
CINATOKEN_CLIENT_ID=your_client_id_here
CINATOKEN_CLIENT_SECRET=your_client_secret_here
CINATOKEN_REDIRECT_URI=http://localhost:3000/oauth/callback
CINATOKEN_SCOPES=user:read user:email

# ===========================================
# CORS 配置
# ===========================================
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Origin,Content-Type,Accept,Authorization,X-CinaToken-Token

# ===========================================
# 日志配置
# ===========================================
LOG_LEVEL=info
LOG_FORMAT=json  # json | text

# ===========================================
# Cloudflare Tunnel 配置
# ===========================================
CLOUDFLARE_TUNNEL_ID=
CLOUDFLARE_DOMAIN=cinaroom.run
